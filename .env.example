PORT=4100
CORS_ORIGIN=http://localhost:4100
BASE_URL=http://localhost:4100
DATABASE_URL=postgresql://captyn:captyn@localhost:5434/landlord_housing?schema=public
ALLOW_MEMORY_FALLBACK_ON_DB_ERROR=false
UPLOADS_DIR=uploads

# Production session isolation.
# Use app-specific names if this app shares a parent domain with another housing app.
USER_SESSION_COOKIE_NAME=landlord_housing_user_session
ADMIN_SESSION_COOKIE_NAME=landlord_housing_admin_session
# Leave blank for host-only cookies. Set to example.com only when intentionally sharing across subdomains.
HOUSING_COOKIE_DOMAIN=
# Leave blank for automatic detection behind a proxy. Set true in HTTPS production if needed.
HOUSING_COOKIE_SECURE=

# Building photos and support evidence upload through this app and are stored under /uploads.
# No third-party image host is required.

# Wi-Fi payment callback security
WIFI_PAYMENT_CALLBACK_TOKEN=change-me-in-production

# Rent M-PESA callback security
MPESA_RENT_CALLBACK_TOKEN=change-rent-callback-token

# M-PESA STK gateway (Daraja)
MPESA_STK_ENABLED=false
MPESA_ENVIRONMENT=sandbox
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_BUSINESS_SHORT_CODE=
MPESA_PARTY_B=
MPESA_PASSKEY=
# If empty, BASE_URL + /api/payments/mpesa/rent-callback is used.
MPESA_CALLBACK_URL=
MPESA_STK_TRANSACTION_TYPE=CustomerPayBillOnline
MPESA_HTTP_TIMEOUT_MS=12000
MPESA_DEBUG_LOGS=false
MPESA_PAYMENT_PROFILES_JSON=[]

# SMS notifications
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SENDER_ID=
NOTIFICATION_SWEEP_TOKEN=

# Admin role tokens (optional if using username/password)
LANDLORD_ACCESS_TOKEN=change-landlord-token
WIFI_ADMIN_TOKEN=change-admin-token
WIFI_ROOT_ADMIN_TOKEN=change-root-admin-token

# Admin credential login
LANDLORD_USERNAME=mashbuildings
LANDLORD_PASSWORD=change-owner-password
ADMIN_USERNAME=opsadmin
ADMIN_PASSWORD=change-admin-password
ROOT_ADMIN_USERNAME=rootops
ROOT_ADMIN_PASSWORD=change-root-password

# Dedicated app seed owner
SEED_OWNER_NAME=Primary Owner
SEED_OWNER_EMAIL=owner@landlord.housing
SEED_OWNER_PHONE=+254700000001
SEED_OWNER_PASSWORD=ChangeMeNow123!
SEED_BUILDING_ID=LANDLORD-BLDG-00001
SEED_BUILDING_NAME=Main Building
SEED_BUILDING_ADDRESS=Set building address
SEED_BUILDING_COUNTY=Nairobi

# MikroTik REST provisioning (optional in dev)
MIKROTIK_API_URL=
MIKROTIK_USERNAME=
MIKROTIK_PASSWORD=
MIKROTIK_HOTSPOT_PROFILE=default
