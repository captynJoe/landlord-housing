# Copy these values into the VPS1 compose environment or .env.vps1.

ESTATEDESK_SERVER_NAME=estatedesk.example.com
ESTATEDESK_CANONICAL_HOST=estatedesk.example.com
ESTATEDESK_PUBLIC_DIR=/home/captyn/landlord-housing/public
ESTATEDESK_API_UPSTREAM=http://<vps2-private-ip>:4110
ESTATEDESK_LOCAL_CERT_DIR=/home/captyn/landlord-housing/deploy/certs
ESTATEDESK_SSL_CERTIFICATE=/etc/estatedesk-certs/estatedesk.example.com/fullchain.pem
ESTATEDESK_SSL_CERTIFICATE_KEY=/etc/estatedesk-certs/estatedesk.example.com/privkey.pem
ESTATEDESK_WEB_CONF=/home/captyn/landlord-housing/deploy/vps1/estatedesk-web.conf
ESTATEDESK_NGINX_TEMPLATE=/home/captyn/landlord-housing/deploy/vps1/estatedesk.vps1.conf.template
