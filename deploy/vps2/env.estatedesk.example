# Copy to /home/captyn/landlord-housing/.env.vps2 on VPS2.

ESTATEDESK_PRIVATE_BIND_IP=<vps2-private-ip>
ESTATEDESK_BASE_URL=https://estatedesk.example.com
ESTATEDESK_CORS_ORIGIN=https://estatedesk.example.com

LANDLORD_HOUSING_DB_PASSWORD=<strong-database-password>

ESTATEDESK_USER_SESSION_COOKIE_NAME=estatedesk_user_session
ESTATEDESK_ADMIN_SESSION_COOKIE_NAME=estatedesk_admin_session
ESTATEDESK_COOKIE_SECURE=true
ESTATEDESK_COOKIE_DOMAIN=

ESTATEDESK_WIFI_PAYMENT_CALLBACK_TOKEN=<strong-wifi-callback-token>
ESTATEDESK_MPESA_RENT_CALLBACK_TOKEN=<strong-rent-callback-token>

ESTATEDESK_MPESA_STK_ENABLED=false
ESTATEDESK_MPESA_ENVIRONMENT=sandbox
ESTATEDESK_MPESA_BASE_URL=https://sandbox.safaricom.co.ke
ESTATEDESK_MPESA_CONSUMER_KEY=
ESTATEDESK_MPESA_CONSUMER_SECRET=
ESTATEDESK_MPESA_BUSINESS_SHORT_CODE=
ESTATEDESK_MPESA_PARTY_B=
ESTATEDESK_MPESA_PASSKEY=
ESTATEDESK_MPESA_CALLBACK_URL=https://estatedesk.example.com/api/payments/mpesa/rent-callback
ESTATEDESK_MPESA_STK_TRANSACTION_TYPE=CustomerPayBillOnline
ESTATEDESK_MPESA_HTTP_TIMEOUT_MS=12000
ESTATEDESK_MPESA_DEBUG_LOGS=false
ESTATEDESK_MPESA_PAYMENT_PROFILES_JSON=[]

ESTATEDESK_RECOVERY_LANDLORD_USERNAME=ownerops
ESTATEDESK_RECOVERY_LANDLORD_PASSWORD=<strong-owner-recovery-password>
ESTATEDESK_RECOVERY_ADMIN_USERNAME=opsadmin
ESTATEDESK_RECOVERY_ADMIN_PASSWORD=<strong-admin-recovery-password>
ESTATEDESK_RECOVERY_ROOT_USERNAME=rootops
ESTATEDESK_RECOVERY_ROOT_PASSWORD=<strong-root-recovery-password>

ESTATEDESK_AFRICASTALKING_API_KEY=
ESTATEDESK_AFRICASTALKING_USERNAME=
ESTATEDESK_AFRICASTALKING_SENDER_ID=
ESTATEDESK_NOTIFICATION_SWEEP_TOKEN=

ESTATEDESK_PUSH_VAPID_PUBLIC_KEY=
ESTATEDESK_PUSH_VAPID_PRIVATE_KEY=
ESTATEDESK_PUSH_VAPID_SUBJECT=mailto:support@example.com
ESTATEDESK_GOOGLE_CLIENT_ID=

ESTATEDESK_MIKROTIK_API_URL=
ESTATEDESK_MIKROTIK_USERNAME=
ESTATEDESK_MIKROTIK_PASSWORD=
ESTATEDESK_MIKROTIK_HOTSPOT_PROFILE=default

ESTATEDESK_SEED_OWNER_NAME=Primary Owner
ESTATEDESK_SEED_OWNER_EMAIL=owner@landlord.housing
ESTATEDESK_SEED_OWNER_PHONE=+254700000001
ESTATEDESK_SEED_OWNER_PASSWORD=<temporary-owner-password>
ESTATEDESK_SEED_BUILDING_ID=LANDLORD-BLDG-00001
ESTATEDESK_SEED_BUILDING_NAME=Main Building
ESTATEDESK_SEED_BUILDING_ADDRESS=Set building address
ESTATEDESK_SEED_BUILDING_COUNTY=Nairobi
ESTATEDESK_RUN_SEED_ON_START=false
